{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TattingCAD",
  "version": "1.1.0",
  "identifier": "com.savarosa.tattingcad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
"app": {
    "windows": [
      {
      "label": "main",
      "title": "TattingCAD",
      "width": 800,
      "height": 600,
      "resizable": true,
      "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
	"category": "GraphicsAndDesign",
	"shortDescription": "Tatting pattern designer",
	"longDescription": "A full-featured design tool for needle and shuttle tatting patterns.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/*.json",
      "../dist/*.md",
      "../dist/*.html"
    ],
	"windows": {
		"nsis": {
			"installerIcon": "icons/icon.ico",
			"sidebarImage": "icons/installer-sidebar.bmp"
				}
			}
  },

    
"plugins": {
    "window-state": null,
"opener": {}
  }
}
