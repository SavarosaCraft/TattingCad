{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TattingCAD",
  "version": "0.1.0",
  "identifier": "com.savarosa.tattingcad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TattingCAD",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/dmc_colors.json",
      "../dist/tatting-help.html",
      "../dist/translations.json",
      "../dist/tatting-theme.json"
    ]
  }
}