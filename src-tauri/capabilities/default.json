{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "dialog:default",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" }
      ]
    }
  ]
}